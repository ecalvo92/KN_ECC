@model List<KN_WEB.EntityFramework.tServicio>


<div class="row g-0 auth-row mt-3 me-3">
    <div class="col-lg-12">

        <table class="table table-responsive">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Imagen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Consecutivo</td>
                        <td>@item.Nombre</td>
                        <td>₡ @item.Precio.ToString("N2")</td>
                        <td>@(item.Estado == 1 ? "Activo" : "Inactivo")</td>
                        <td>@item.Imagen</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
