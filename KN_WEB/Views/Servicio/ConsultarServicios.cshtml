@model List<KN_WEB.EntityFramework.tServicio>

<div class="row">
    <div class="col-12">
        <div class="section-title mb-3">
            <h4>Servicios</h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card-style">

            <table class="table table-responsive">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th>Imagen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Consecutivo</td>
                            <td>@item.Nombre</td>
                            <td>₡ @item.Precio.ToString("N2")</td>
                            <td>@(item.Estado == 1 ? "Activo" : "Inactivo")</td>
                            <td>@item.Imagen</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>
